{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "additionalProperties": false,
  "definitions": {
    "Entry": {
      "anyOf": [
        {
          "description": "Directory relative to effective root (or . for root).",
          "type": "string"
        },
        {
          "$ref": "#/definitions/EntryOptions"
        }
      ],
      "title": "Entry"
    },
    "EntryOptions": {
      "additionalProperties": false,
      "properties": {
        "cmd": {
          "description": "Command sent to the session after create (tmux send-keys).",
          "type": [
            "string",
            "null"
          ],
          "x-taplo": {
            "initKeys": [
              "dir",
              "windows",
              "cmd"
            ]
          }
        },
        "dir": {
          "description": "Directory relative to effective root.",
          "type": "string",
          "x-taplo": {
            "initKeys": [
              "dir",
              "windows",
              "cmd"
            ]
          }
        },
        "windows": {
          "anyOf": [
            {
              "$ref": "#/definitions/WindowsSpec"
            },
            {
              "type": "null"
            }
          ],
          "description": "Override window count or provide detailed layout for this entry.",
          "x-taplo": {
            "initKeys": [
              "dir",
              "windows",
              "cmd"
            ]
          }
        }
      },
      "required": [
        "dir"
      ],
      "type": "object",
      "x-taplo": {
        "initKeys": [
          "dir",
          "windows",
          "cmd"
        ]
      }
    },
    "PaneSpec": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "properties": {
            "cmd": {
              "type": [
                "string",
                "null"
              ]
            },
            "dir": {
              "type": [
                "string",
                "null"
              ]
            },
            "split": {
              "anyOf": [
                {
                  "$ref": "#/definitions/SplitDirection"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "type": "object"
        }
      ]
    },
    "SplitDirection": {
      "enum": [
        "horizontal",
        "vertical"
      ],
      "type": "string"
    },
    "WindowSpec": {
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "panes": {
          "items": {
            "$ref": "#/definitions/PaneSpec"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "WindowsSpec": {
      "anyOf": [
        {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        {
          "items": {
            "$ref": "#/definitions/WindowSpec"
          },
          "type": "array"
        }
      ]
    },
    "WorktreeOverrides": {
      "additionalProperties": false,
      "properties": {
        "root": {
          "description": "Direct checkout root for this worktree. Does not append the worktree name.",
          "type": [
            "string",
            "null"
          ],
          "x-taplo": {
            "initKeys": [
              "root",
              "windows",
              "worktree_parent"
            ]
          }
        },
        "windows": {
          "description": "Default window count when using this worktree.",
          "format": "uint32",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ],
          "x-taplo": {
            "initKeys": [
              "root",
              "windows",
              "worktree_parent"
            ]
          }
        },
        "worktree_parent": {
          "description": "Override worktree parent for this worktree only.",
          "type": [
            "string",
            "null"
          ],
          "x-taplo": {
            "initKeys": [
              "root",
              "windows",
              "worktree_parent"
            ]
          }
        }
      },
      "type": "object",
      "x-taplo": {
        "initKeys": [
          "root",
          "windows",
          "worktree_parent"
        ]
      }
    }
  },
  "description": "tmux session definitions for tm. Top-level keys are config names (e.g. kuib-ai, portfolios).",
  "patternProperties": {
    "^[a-zA-Z][a-zA-Z0-9._-]*$": {
      "additionalProperties": false,
      "properties": {
        "entries": {
          "additionalProperties": {
            "$ref": "#/definitions/Entry"
          },
          "description": "Session entries: key is session suffix, value is directory or options.",
          "type": "object"
        },
        "root": {
          "description": "Project root. Absolute path, ~/…, or bare relative (resolved under $HOME).",
          "type": [
            "string",
            "null"
          ]
        },
        "windows": {
          "default": 2,
          "description": "Default window count per session.",
          "format": "uint32",
          "minimum": 1,
          "type": "integer"
        },
        "worktree_parent": {
          "description": "Worktree parent directory (relative to root unless absolute). Used with `tm start -w <name>`.",
          "type": [
            "string",
            "null"
          ]
        },
        "worktree_prefix": {
          "description": "Session path segment for worktrees. `{name}` is replaced with the -w argument.",
          "examples": [
            "worktree-{name}"
          ],
          "type": [
            "string",
            "null"
          ]
        },
        "worktrees": {
          "additionalProperties": {
            "$ref": "#/definitions/WorktreeOverrides"
          },
          "description": "Per-worktree overrides keyed by worktree name.",
          "type": "object"
        }
      },
      "required": [
        "entries"
      ],
      "type": "object",
      "x-taplo": {
        "docs": {
          "main": "A tmux-manager config (project). Top-level TOML: `[name]` + `[name.entries]` + optional `[name.worktrees.\"…\"]`."
        },
        "initKeys": [
          "root",
          "windows",
          "worktree_parent",
          "worktree_prefix",
          "entries",
          "worktrees"
        ]
      }
    }
  },
  "title": "tmux-manager config",
  "type": "object"
}